<Window x:Class="SJ_CADtoRevit.ExtractWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="다중 도곽 DWG 추출" Height="540" Width="420"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="CanResize" MinHeight="400" MinWidth="380" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI, Malgun Gothic">
    <Window.Resources>
        <!-- Custom Button Style -->
        <Style x:Key="RunButton" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0052D4" Offset="0"/>
                        <GradientStop Color="#00B4DB" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="5" 
                                SnapsToDevicePixels="true">
                            <Border.Effect>
                                <DropShadowEffect Color="#00D2FF" BlurRadius="5" ShadowDepth="1" Opacity="0.2"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter TargetName="border" Property="Background" Value="#2D2D37"/>
                                <Setter Property="Foreground" Value="#6D6D7C"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#0043B4" Offset="0"/>
                                            <GradientStop Color="#009EC3" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#003185" Offset="0"/>
                                            <GradientStop Color="#007E9C" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom GridView Column Header Style -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#141419"/>
            <Setter Property="Foreground" Value="#8E8E9F"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#2D2D37"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <!-- Custom ListViewItem Style -->
        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#1F1F26"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="bg" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <GridViewRowPresenter Content="{TemplateBinding Content}" Columns="{TemplateBinding GridView.ColumnCollection}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="true">
                                <Setter TargetName="bg" Property="Background" Value="#0F355C"/>
                                <Setter Property="BorderBrush" Value="#00D2FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="bg" Property="Background" Value="#181822"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderThickness="1.5" BorderBrush="#00D2FF" CornerRadius="8" Background="#1E1E24" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="130"/> <!-- Log Terminal -->
                <RowDefinition Height="*"/>   <!-- ListView Area -->
                <RowDefinition Height="Auto"/> <!-- Status & Controls -->
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Grid Grid.Row="0" Background="#141419" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0,0,0">
                    <TextBlock Text="다중 도곽 DWG 추출" 
                               Foreground="#00D2FF" 
                               FontSize="14" 
                               FontWeight="Bold" 
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" - Revit 전환설계" 
                               Foreground="#8E8E9F" 
                               FontSize="11.5" 
                               VerticalAlignment="Center"
                               Margin="5,0,0,0"/>
                </StackPanel>

                <!-- Close Button -->
                <Button Grid.Column="1" 
                        x:Name="btnClose" 
                        Content="✕" 
                        Foreground="#6D6D7C" 
                        Background="Transparent" 
                        BorderThickness="0" 
                        FontSize="16" 
                        Cursor="Hand"
                        Click="btnClose_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg" Background="Transparent">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="true">
                                                <Setter TargetName="bg" Property="Background" Value="#E81123"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Execution Log Terminal -->
            <Grid Grid.Row="1" Margin="15,10,15,5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" 
                           Text="작업 진행 상태 및 로그" 
                           Foreground="#E2E2E6" 
                           FontSize="11.5" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,3"/>
                <Border Grid.Row="1" 
                        Background="#101014" 
                        BorderBrush="#2D2D37" 
                        BorderThickness="1" 
                        CornerRadius="4" 
                        Padding="6">
                    <TextBox x:Name="txtLog" 
                             Background="Transparent" 
                             BorderThickness="0" 
                             Foreground="#A3E281" 
                             FontFamily="Consolas, Courier New" 
                             FontSize="10.5" 
                             IsReadOnly="True" 
                             VerticalScrollBarVisibility="Auto" 
                             HorizontalScrollBarVisibility="Auto" 
                             TextWrapping="Wrap"
                             Text="[대기 중] 먼저 도곽을 인식(자동 스캔 혹은 수동 지정)하십시오."/>
                </Border>
            </Grid>

            <!-- ListView Area (in the center) -->
            <Grid Grid.Row="2" Margin="15,5,15,5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" 
                           Text="인식된 도곽 목록 (클릭 시 캐드 화면 이동 및 파일명 개별 수정 가능)" 
                           Foreground="#E2E2E6" 
                           FontSize="11.5" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,3"/>
                
                <ListView Grid.Row="1" 
                          x:Name="lstBoundaries" 
                          Background="#101014" 
                          BorderBrush="#2D2D37" 
                          BorderThickness="1" 
                          SelectionChanged="lstBoundaries_SelectionChanged"
                          KeyDown="lstBoundaries_KeyDown"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="번호" Width="35">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Index}" Foreground="#8E8E9F" HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="도곽 정보" Width="125">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Description}" ToolTip="{Binding Description}" TextTrimming="CharacterEllipsis"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="저장 파일명 (수정 가능)" Width="180">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding FileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                 Background="#1E1E24" 
                                                 Foreground="White" 
                                                 BorderBrush="#2D2D37" 
                                                 BorderThickness="1" 
                                                 Height="22" 
                                                 Width="170"
                                                 Padding="3,1,3,0"
                                                 FontSize="11"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="작업" Width="50">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="제거" 
                                                Click="btnDeleteRow_Click"
                                                Tag="{Binding}"
                                                Background="#FF3B30" 
                                                Foreground="White" 
                                                BorderThickness="0" 
                                                FontSize="10" 
                                                Height="18" 
                                                Padding="5,0,5,0"
                                                Cursor="Hand">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="3"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>

            <!-- Control & Extraction Action -->
            <StackPanel Grid.Row="3" Margin="15,5,15,15" Orientation="Vertical">
                <!-- Status Panel -->
                <Border Background="#141419" BorderBrush="#2D2D37" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="인식 상태: " Foreground="#8E8E9F" FontSize="12"/>
                        <TextBlock x:Name="lblStatus" Text="대기 중 (도곽 없음)" Foreground="#00D2FF" FontWeight="Bold" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Action Buttons (Grid) -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Scan / Detect Buttons -->
                    <Button x:Name="btnAutoDetect" 
                            Grid.Row="0" Grid.Column="0"
                            Content="자동 도곽 스캔" 
                            Style="{StaticResource RunButton}" 
                            Margin="0,0,3,5"
                            Click="btnAutoDetect_Click"/>
                    
                    <Button x:Name="btnManualDetect" 
                            Grid.Row="0" Grid.Column="1"
                            Content="수동 도곽 지정" 
                            Style="{StaticResource RunButton}" 
                            Margin="3,0,0,5"
                            Click="btnManualDetect_Click"/>
                    
                    <!-- Run Extract (Full Width) -->
                    <Button x:Name="btnExtract" 
                            Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                            Content="선택한 도면 추출 실행" 
                            Style="{StaticResource RunButton}" 
                            Margin="0,5,0,0"
                            IsEnabled="False"
                            Click="btnExtract_Click"/>
                </Grid>
                
                <TextBlock Text="* 리스트 항목 선택 시 캐드 뷰가 해당 도곽으로 줌 이동합니다." 
                           Foreground="#6D6D7C" 
                           FontSize="10" 
                           HorizontalAlignment="Center" 
                           Margin="0,8,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
